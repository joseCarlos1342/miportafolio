---
import type { Locale } from "../../types";

interface Props {
	text: Record<Locale, string>;
	variant?: "default" | "on-dark";
}

const { text, variant = "default" } = Astro.props;
const colorClass =
	variant === "on-dark"
		? "text-[color:var(--primary-on-dark)]"
		: "text-[color:var(--primary)]";
---

<p
	class={`mb-4 text-sm font-semibold uppercase tracking-[0.24em] ${colorClass}`}
	data-es={text.es}
	data-en={text.en}
>
	{text.es}
</p>
