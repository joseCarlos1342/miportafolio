---
interface Props {
	href?: string;
	large?: boolean;
	variant?: "primary" | "outline" | "ghost";
	target?: string;
	rel?: string;
	download?: boolean;
	ariaLabel?: string;
	ariaLabelEs?: string;
	ariaLabelEn?: string;
	icon?: boolean;
}

const {
	href,
	large = false,
	variant = "primary",
	target,
	rel,
	download,
	ariaLabel,
	ariaLabelEs,
	ariaLabelEn,
	icon = false,
} = Astro.props;

const sizeClass = large ? "px-6 py-3 text-base" : "px-5 py-3 text-sm";
const variantClass =
	variant === "primary"
		? "bg-[color:var(--primary)] text-white"
		: variant === "outline"
			? "border border-[color:var(--primary)] text-[color:var(--primary)]"
			: "border border-[color:var(--hairline)] text-[color:var(--ink)]";
const cls = `magnetic inline-flex min-h-11 items-center justify-center gap-2 rounded-full transition active:scale-95 ${sizeClass} ${variantClass}`;
---

<a
	href={href}
	target={target}
	rel={rel}
	download={download}
	aria-label={ariaLabel}
	data-i18n-aria-es={ariaLabelEs}
	data-i18n-aria-en={ariaLabelEn}
	class={cls}
>
	<slot />
	{
		icon && (
			<svg
				aria-hidden="true"
				width="18"
				height="18"
				viewBox="0 0 24 24"
				fill="none"
			>
				<path
					d="M7 17 17 7M9 7h8v8"
					stroke="currentColor"
					stroke-width="1.8"
					stroke-linecap="round"
					stroke-linejoin="round"
				/>
			</svg>
		)
	}
</a>
