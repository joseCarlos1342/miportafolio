---
import { navLinks } from "../../data/nav";
import { es, en } from "../../data/i18n/strings";
import LanguageSwitch from "../i18n/LanguageSwitch.astro";
import ThemeToggle from "../theme/ThemeToggle.astro";
---

<header
	class="fixed inset-x-0 top-0 z-50 border-b border-[color:var(--hairline)] bg-[color:var(--canvas)]/82 backdrop-blur-xl"
>
	<nav
		class="mx-auto flex h-16 max-w-7xl items-center justify-between px-5 sm:px-8"
		aria-label="Navegación principal"
		data-i18n-aria-es="Navegación principal"
		data-i18n-aria-en="Main navigation"
	>
		<a
			href="#top"
			class="text-sm font-semibold tracking-[-0.02em] text-[color:var(--ink)]"
		>
			JCG
		</a>
		<div
			class="hidden items-center gap-7 text-sm text-[color:var(--body-muted)] md:flex"
		>
			{
				navLinks.map((link) => (
					<a
						href={link.href}
						class="transition hover:text-[color:var(--ink)]"
						data-es={link.label.es}
						data-en={link.label.en}
					>
						{link.label.es}
					</a>
				))
			}
		</div>
		<div class="flex items-center gap-2">
			<LanguageSwitch />
			<ThemeToggle />
		</div>
	</nav>
</header>
<span class="sr-only" data-es={es["nav.projects"]} data-en={en["nav.projects"]}></span>
