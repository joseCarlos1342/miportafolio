---
import { site } from "../../data/site";
import { es, en } from "../../data/i18n/strings";
import SectionHeading from "../ui/SectionHeading.astro";
---

<section
	id="contact"
	class="relative overflow-hidden bg-[color:var(--canvas)] px-5 py-24 sm:px-8"
	aria-labelledby="contact-title"
>
	<div
		class="absolute left-1/2 top-10 h-80 w-80 -translate-x-1/2 rounded-full bg-[color:var(--primary)]/10 blur-3xl"
	>
	</div>
	<div class="reveal contact-shell mx-auto max-w-5xl">
		<div class="contact-copy">
			<SectionHeading
				id="contact-title"
				text={{ es: es["contact.title"], en: en["contact.title"] }}
			/>
			<p
				class="mt-6 max-w-2xl text-lg leading-8 text-[color:var(--body-muted)]"
				data-es={es["contact.subtitle"]}
				data-en={en["contact.subtitle"]}
			>
				{es["contact.subtitle"]}
			</p>
		</div>

		<div class="contact-panel">
			<div>
				<p
					class="text-sm uppercase tracking-[0.22em] text-[color:var(--primary)]"
					data-es={es["contact.eyebrow"]}
					data-en={en["contact.eyebrow"]}
				>
					{es["contact.eyebrow"]}
				</p>
				<p
					class="contact-email"
					data-es={es["contact.helper"]}
					data-en={en["contact.helper"]}
				>
					{es["contact.helper"]}
				</p>
			</div>
			<div class="contact-actions">
				<a
					href={site.social.linkedin}
					target="_blank"
					rel="noreferrer"
					class="contact-action contact-action--primary magnetic"
				>
					<span>LinkedIn</span>
					<svg
						aria-hidden="true"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
					>
						<path
							d="M7 17 17 7M9 7h8v8"
							stroke="currentColor"
							stroke-width="1.8"
							stroke-linecap="round"
							stroke-linejoin="round"
						></path>
					</svg>
				</a>
				<a
					href={site.social.github}
					target="_blank"
					rel="noreferrer"
					class="contact-action magnetic"
				>
					GitHub
				</a>
				<a
					href={site.protected.downloadCvPath}
					class="contact-action magnetic"
					data-es={es["hero.cta.cv"]}
					data-en={en["hero.cta.cv"]}
				>
					{es["hero.cta.cv"]}
				</a>
				<a
					href={site.protected.emailPath}
					class="contact-action magnetic"
					aria-label={es["contact.viewEmail"]}
					data-i18n-aria-es={es["contact.viewEmail"]}
					data-i18n-aria-en={en["contact.viewEmail"]}
				>
					<svg
						aria-hidden="true"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
					>
						<path
							d="M4 6.5A2.5 2.5 0 0 1 6.5 4h11A2.5 2.5 0 0 1 20 6.5v11a2.5 2.5 0 0 1-2.5 2.5h-11A2.5 2.5 0 0 1 4 17.5v-11Z"
							stroke="currentColor"
							stroke-width="1.7"></path>
						<path
							d="m5 7 7 6 7-6"
							stroke="currentColor"
							stroke-width="1.7"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
					<span data-es={es["contact.viewEmail"]} data-en={en["contact.viewEmail"]}>
						{es["contact.viewEmail"]}
					</span>
				</a>
			</div>
			<p
				id="copyStatus"
				class="min-h-6 text-sm text-[color:var(--body-muted)]"
				role="status"
				aria-live="polite"
			>
			</p>
		</div>
	</div>
</section>
