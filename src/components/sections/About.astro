---
import { es, en } from "../../data/i18n/strings";
import SectionHeading from "../ui/SectionHeading.astro";
---

<section
	class="bg-[color:var(--canvas-parchment)] px-5 py-24 sm:px-8"
	aria-labelledby="about-title"
>
	<div
		class="reveal mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.9fr_1.1fr]"
	>
		<SectionHeading
			id="about-title"
			text={{ es: es["about.title"], en: en["about.title"] }}
		/>
		<div
			class="space-y-6 text-lg leading-8 tracking-[-0.025em] text-[color:var(--body-muted)]"
		>
			<p data-es={es["about.body1"]} data-en={en["about.body1"]}>
				{es["about.body1"]}
			</p>
			<p data-es={es["about.body2"]} data-en={en["about.body2"]}>
				{es["about.body2"]}
			</p>
		</div>
	</div>
</section>
