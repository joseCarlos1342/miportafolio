---
import "../styles/global.css";

const siteUrl = "https://portafoliojosecarlos.com";
const siteTitle = "José Carlos Gómez R. | Ingeniero de Software Full-Stack";
const siteDescription = "Portafolio de José Carlos Gómez R., ingeniero Full-Stack especializado en React, Next.js, Python, PostgreSQL y Supabase.";
const socialDescription = "Proyectos Full-Stack con seguridad, tiempo real, datos y experiencias web modernas listas para producción.";
const socialImage = `${siteUrl}/og-image.png?v=2`;
const linkedin = "https://www.linkedin.com/in/josecarlos-gomez-ing";
const github = "https://github.com/joseCarlos1342";
const cv = "/docs/cv-jose-carlos-gomez.pdf";
const protectedEmail = "/__contact-email";
const projectLinks = {
	finance: "https://github.com/joseCarlos1342/Mis_gastos_mensuales",
	loans: "https://github.com/joseCarlos1342/Sistema_prestamos_personales",
	game: "https://github.com/joseCarlos1342/Mesa_primera",
};
const createScreens = (folder: string) => Array.from({ length: 7 }, (_, index) => {
	const path = `/projects/${folder}/preview-${index + 1}`;
	return {
		png: `${path}.png`,
		webp: `${path}.webp`,
		avif: `${path}.avif`,
	};
});
const financeScreens = createScreens("mis-gastos");
const loanScreens = createScreens("prestamos");
const structuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "Person",
			"@id": `${siteUrl}/#person`,
			name: "José Carlos Gómez R.",
			url: siteUrl,
			image: `${siteUrl}/profile.png`,
			jobTitle: "Ingeniero de Software Full-Stack",
			description: siteDescription,
			sameAs: [linkedin, github],
			knowsAbout: ["React", "Next.js", "Astro", "Node.js", "Python", "Flask", "PostgreSQL", "Supabase", "Redis", "Seguridad web", "Sistemas en tiempo real"],
		},
		{
			"@type": "WebSite",
			"@id": `${siteUrl}/#website`,
			url: siteUrl,
			name: "Portafolio de José Carlos Gómez R.",
			description: siteDescription,
			inLanguage: "es-CO",
			publisher: { "@id": `${siteUrl}/#person` },
		},
	],
};
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="canonical" href={`${siteUrl}/`} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={siteDescription} />
		<meta name="author" content="José Carlos Gómez R." />
		<meta name="creator" content="José Carlos Gómez R." />
		<meta name="robots" content="index, follow, max-image-preview:large" />
		<meta name="keywords" content="José Carlos Gómez, ingeniero de software, desarrollador full-stack, React, Next.js, Astro, Node.js, Python, Flask, PostgreSQL, Supabase, Redis, portafolio desarrollador Colombia" />
		<meta name="application-name" content="Portafolio José Carlos Gómez R." />
		<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
		<meta property="og:locale" content="es_CO" />
		<meta property="og:site_name" content="Portafolio José Carlos Gómez R." />
		<meta property="og:url" content={`${siteUrl}/`} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={siteTitle} />
		<meta property="og:description" content={socialDescription} />
		<meta property="og:image" content={socialImage} />
		<meta property="og:image:secure_url" content={socialImage} />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="Portafolio de José Carlos Gómez R., ingeniero de software Full-Stack" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={siteTitle} />
		<meta name="twitter:description" content={socialDescription} />
		<meta name="twitter:image" content={socialImage} />
		<meta name="twitter:image:alt" content="Portafolio de José Carlos Gómez R., ingeniero de software Full-Stack" />
		<title>{siteTitle}</title>
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
		<script is:inline>
			(() => {
				document.documentElement.classList.add("js");
				history.scrollRestoration = "manual";
				if (location.hash) history.replaceState(null, "", location.pathname + location.search);
				window.scrollTo(0, 0);
				const storedTheme = localStorage.getItem("theme");
				const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
				const theme = storedTheme === "dark" || storedTheme === "light" ? storedTheme : prefersDark ? "dark" : "light";
				document.documentElement.classList.toggle("dark", theme === "dark");
				document.documentElement.dataset.theme = theme;
			})();
		</script>
	</head>
	<body class="min-h-screen overflow-x-hidden">
		<a class="skip-link" href="#main" data-es="Saltar al contenido" data-en="Skip to content">Saltar al contenido</a>

		<header class="fixed inset-x-0 top-0 z-50 border-b border-[color:var(--hairline)] bg-[color:var(--canvas)]/82 backdrop-blur-xl">
			<nav class="mx-auto flex h-16 max-w-7xl items-center justify-between px-5 sm:px-8" aria-label="Navegación principal" data-i18n-aria-es="Navegación principal" data-i18n-aria-en="Main navigation">
				<a href="#top" class="text-sm font-semibold tracking-[-0.02em] text-[color:var(--ink)]">JCG</a>
				<div class="hidden items-center gap-7 text-sm text-[color:var(--body-muted)] md:flex">
					<a href="#projects" class="transition hover:text-[color:var(--ink)]" data-es="Proyectos" data-en="Projects">Proyectos</a>
					<a href="#skills" class="transition hover:text-[color:var(--ink)]" data-es="Stack" data-en="Stack">Stack</a>
					<a href="#contact" class="transition hover:text-[color:var(--ink)]" data-es="Contacto" data-en="Contact">Contacto</a>
				</div>
				<div class="flex items-center gap-2">
					<button id="languageToggle" class="magnetic min-h-11 rounded-full border border-[color:var(--hairline)] px-4 text-sm font-medium text-[color:var(--ink)] transition active:scale-95" type="button" aria-label="Cambiar idioma a inglés" data-i18n-aria-es="Cambiar idioma a inglés" data-i18n-aria-en="Switch language to Spanish">EN</button>
					<button id="themeToggle" class="magnetic min-h-11 rounded-full border border-[color:var(--hairline)] px-4 text-sm font-medium text-[color:var(--ink)] transition active:scale-95" type="button" aria-label="Cambiar tema" data-i18n-aria-es="Cambiar tema" data-i18n-aria-en="Toggle theme" aria-pressed="false">
						<span class="theme-label">Dark</span>
					</button>
				</div>
			</nav>
		</header>

		<main id="main">
			<section id="top" class="relative isolate flex min-h-screen items-center overflow-hidden bg-[color:var(--canvas)] px-5 pt-28 sm:px-8">
				<div class="absolute inset-x-0 top-16 -z-10 h-px bg-[color:var(--hairline)]"></div>
				<div class="absolute right-[-16rem] top-24 -z-10 h-[32rem] w-[32rem] rounded-full bg-[color:var(--primary)]/10 blur-3xl"></div>
				<div class="mx-auto grid w-full max-w-7xl items-center gap-16 lg:grid-cols-[1.05fr_0.95fr]">
					<div class="reveal max-w-4xl">
						<p class="mb-6 inline-flex rounded-full border border-[color:var(--hairline)] px-4 py-2 text-sm font-medium text-[color:var(--body-muted)]" data-es="Full-Stack, seguridad y sistemas en tiempo real" data-en="Full-stack, security and real-time systems">Full-Stack, seguridad y sistemas en tiempo real</p>
						<h1 class="max-w-5xl text-5xl font-semibold leading-[0.98] tracking-[-0.055em] text-[color:var(--ink)] sm:text-7xl lg:text-[6.7rem]">
							José Carlos<br />Gómez R.
						</h1>
						<p class="mt-8 max-w-2xl text-xl font-light leading-8 tracking-[-0.03em] text-[color:var(--body-muted)] sm:text-2xl sm:leading-10" data-es="Construyo aplicaciones web claras, rápidas y seguras: desde paneles de control y PWAs hasta sistemas con datos en tiempo real, Supabase, PostgreSQL y despliegues listos para producción." data-en="I build clear, fast and secure web applications: from dashboards and PWAs to real-time data systems with Supabase, PostgreSQL and production-ready deployments.">Construyo aplicaciones web claras, rápidas y seguras: desde paneles de control y PWAs hasta sistemas con datos en tiempo real, Supabase, PostgreSQL y despliegues listos para producción.</p>
						<div class="mt-10 flex flex-col gap-3 sm:flex-row">
							<a href="#projects" class="magnetic inline-flex min-h-11 items-center justify-center rounded-full bg-[color:var(--primary)] px-6 py-3 text-base text-white transition active:scale-95" data-es="Ver proyectos" data-en="View projects">Ver proyectos</a>
							<a href={linkedin} target="_blank" rel="noreferrer" class="magnetic inline-flex min-h-11 items-center justify-center rounded-full border border-[color:var(--primary)] px-6 py-3 text-base text-[color:var(--primary)] transition active:scale-95" data-es="LinkedIn" data-en="LinkedIn">LinkedIn</a>
							<a href={cv} download class="magnetic inline-flex min-h-11 items-center justify-center rounded-full border border-[color:var(--hairline)] px-6 py-3 text-base text-[color:var(--ink)] transition active:scale-95" data-es="Descargar CV" data-en="Download CV">Descargar CV</a>
						</div>
					</div>

					<div class="reveal relative mx-auto w-full max-w-[32rem] lg:ml-auto">
						<div class="photo-placeholder overflow-hidden rounded-[2rem] border border-[color:var(--hairline)] p-4 shadow-[var(--shadow-product)] sm:p-5">
							<div class="overflow-hidden rounded-[1.45rem] border border-[color:var(--hairline)] bg-[color:var(--canvas)]/65 backdrop-blur-xl">
								<img class="h-[22rem] w-full object-cover object-[50%_30%]" src="/profile.png" alt="Foto profesional de José Carlos Gómez R." />
							</div>
							<div class="mt-4 rounded-[1.45rem] bg-[color:var(--surface-dark)] p-5 text-white">
								<div class="mb-5 flex items-center gap-2" aria-hidden="true">
									<span class="h-3 w-3 rounded-full bg-[#ff5f57]"></span>
									<span class="h-3 w-3 rounded-full bg-[#ffbd2e]"></span>
									<span class="h-3 w-3 rounded-full bg-[#28c840]"></span>
								</div>
								<p class="text-sm text-white/58">~/portfolio</p>
								<p class="mt-4 font-mono text-2xl leading-10 tracking-[-0.04em] sm:text-3xl">
									<span class="text-[#7dd3fc]">build</span>(secureProducts)<br />
									<span class="text-[#86efac]">deploy</span>(fastExperiences)<br />
									<span class="text-[#f0abfc]">scale</span>(realTimeSystems)
								</p>
								<div class="mt-8 grid grid-cols-3 gap-3 text-center text-xs text-white/64">
									<div class="rounded-2xl bg-white/8 p-4"><strong class="block text-lg text-white">PWA</strong><span>offline-ready</span></div>
									<div class="rounded-2xl bg-white/8 p-4"><strong class="block text-lg text-white">RLS</strong><span>secure data</span></div>
									<div class="rounded-2xl bg-white/8 p-4"><strong class="block text-lg text-white">RTC</strong><span>low latency</span></div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section class="bg-[color:var(--canvas-parchment)] px-5 py-24 sm:px-8" aria-labelledby="about-title">
				<div class="reveal mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.9fr_1.1fr]">
						<h2 id="about-title" class="text-4xl font-semibold tracking-[-0.045em] text-[color:var(--ink)] sm:text-6xl" data-es="Desarrollo con enfoque práctico." data-en="Practical product-focused development.">Desarrollo con enfoque práctico.</h2>
						<div class="space-y-6 text-lg leading-8 tracking-[-0.025em] text-[color:var(--body-muted)]">
						<p data-es="Actualmente estudio Ingeniería de Software y trabajo proyectos Full-Stack donde combino frontend, backend, bases de datos, seguridad y despliegue." data-en="I am currently studying Software Engineering and work on full-stack projects that combine frontend, backend, databases, security and deployment.">Actualmente estudio Ingeniería de Software y trabajo proyectos Full-Stack donde combino frontend, backend, bases de datos, seguridad y despliegue.</p>
						<p data-es="Me gusta construir productos que se entiendan rápido, respondan bien y sean confiables para quien los usa: interfaces limpias, arquitectura simple y detalles cuidados sin complicar de más." data-en="I like building products that are easy to understand, responsive and reliable for users: clean interfaces, simple architecture and careful details without overcomplicating things.">Me gusta construir productos que se entiendan rápido, respondan bien y sean confiables para quien los usa: interfaces limpias, arquitectura simple y detalles cuidados sin complicar de más.</p>
					</div>
				</div>
			</section>

			<section id="skills" class="bg-[color:var(--canvas)] px-5 py-24 sm:px-8" aria-labelledby="skills-title">
				<div class="mx-auto max-w-7xl">
					<div class="reveal mb-12 flex flex-col justify-between gap-5 sm:flex-row sm:items-end">
						<h2 id="skills-title" class="max-w-2xl text-4xl font-semibold tracking-[-0.045em] sm:text-6xl" data-es="Tecnologías que uso para construir." data-en="Technologies I use to build.">Tecnologías que uso para construir.</h2>
						<p class="max-w-md text-lg leading-8 text-[color:var(--body-muted)]" data-es="Herramientas que he usado en interfaces, APIs, bases de datos, seguridad y despliegues." data-en="Tools I have used across interfaces, APIs, databases, security and deployments.">Herramientas que he usado en interfaces, APIs, bases de datos, seguridad y despliegues.</p>
					</div>
					<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
						<div class="reveal rounded-[1.25rem] border border-[color:var(--hairline)] bg-[color:var(--surface-raised)] p-6">
							<h3 class="text-xl font-semibold" data-es="Frontend" data-en="Frontend">Frontend</h3>
							<div class="mt-5 grid gap-3">
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #f7df1e"><img class="tech-logo" src="/tech/js.svg" alt="" loading="lazy"/><span>JavaScript</span></div>
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #3178c6"><img class="tech-logo" src="/tech/typescript.svg" alt="" loading="lazy"/><span>TypeScript</span></div>
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #61dafb"><img class="tech-logo" src="/tech/react.svg" alt="" loading="lazy"/><span>React</span></div>
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #ffffff"><img class="tech-logo" src="/tech/nextjs.svg" alt="" loading="lazy"/><span>Next.js</span></div>
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #ff5d01"><img class="tech-logo" src="/tech/astro.svg" alt="" loading="lazy"/><span>Astro</span></div>
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #38bdf8"><img class="tech-logo" src="/tech/tailwind.svg" alt="" loading="lazy"/><span>Tailwind CSS</span></div>
							</div>
						</div>
						<div class="reveal rounded-[1.25rem] border border-[color:var(--hairline)] bg-[color:var(--surface-raised)] p-6">
							<h3 class="text-xl font-semibold" data-es="Backend" data-en="Backend">Backend</h3>
							<div class="mt-5 grid gap-3">
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #5fa04e"><img class="tech-logo" src="/tech/nodejs.svg" alt="" loading="lazy"/><span>Node.js</span></div>
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #ffffff"><img class="tech-logo" src="/tech/express.svg" alt="" loading="lazy"/><span>Express</span></div>
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #3776ab"><img class="tech-logo" src="/tech/python.svg" alt="" loading="lazy"/><span>Python</span></div>
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #000000"><img class="tech-logo" src="/tech/flask.svg" alt="" loading="lazy"/><span>Flask</span></div>
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #8b5cf6"><img class="tech-logo" src="/tech/microservices.svg" alt="" loading="lazy"/><span data-es="Microservicios" data-en="Microservices">Microservicios</span></div>
							</div>
						</div>
						<div class="reveal rounded-[1.25rem] border border-[color:var(--hairline)] bg-[color:var(--surface-raised)] p-6">
							<h3 class="text-xl font-semibold" data-es="Datos y cloud" data-en="Data and cloud">Datos y cloud</h3>
							<div class="mt-5 grid gap-3">
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #4169e1"><img class="tech-logo" src="/tech/postgresql.svg" alt="" loading="lazy"/><span>PostgreSQL</span></div>
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #3ecf8e"><img class="tech-logo" src="/tech/supabase.svg" alt="" loading="lazy"/><span>Supabase</span></div>
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #dc382d"><img class="tech-logo" src="/tech/redis.svg" alt="" loading="lazy"/><span>Redis</span></div>
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #003b57"><img class="tech-logo" src="/tech/sqlite.svg" alt="" loading="lazy"/><span>SQLite</span></div>
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #7c3aed"><img class="tech-logo" src="/tech/railway.svg" alt="" loading="lazy"/><span>Railway</span></div>
							</div>
						</div>
						<div class="reveal rounded-[1.25rem] border border-[color:var(--hairline)] bg-[color:var(--surface-raised)] p-6">
							<h3 class="text-xl font-semibold" data-es="Seguridad" data-en="Security">Seguridad</h3>
							<div class="mt-5 grid gap-3">
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #f97316"><img class="tech-logo" src="/tech/jwt.svg" alt="" loading="lazy"/><span>JWT</span></div>
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #14b8a6"><img class="tech-logo" src="/tech/totp.svg" alt="" loading="lazy"/><span>TOTP / 2FA</span></div>
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #64748b"><img class="tech-logo" src="/tech/aes.svg" alt="" loading="lazy"/><span>AES-256</span></div>
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #3ecf8e"><img class="tech-logo" src="/tech/rls.svg" alt="" loading="lazy"/><span>Row Level Security</span></div>
								<div class="tech-pill flex items-center gap-3 rounded-2xl border border-[color:var(--hairline)] p-3" style="--tech-color: #111827"><img class="tech-logo" src="/tech/linux.svg" alt="" loading="lazy"/><span>Linux Admin</span></div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section id="projects" class="bg-[color:var(--surface-dark)] px-5 py-24 text-white sm:px-8" aria-labelledby="projects-title">
				<div class="mx-auto max-w-7xl">
					<div class="reveal mb-14 max-w-4xl">
						<p class="mb-4 text-sm font-semibold uppercase tracking-[0.24em] text-[color:var(--primary-on-dark)]" data-es="Proyectos destacados" data-en="Featured projects">Proyectos destacados</p>
						<h2 id="projects-title" class="text-4xl font-semibold tracking-[-0.045em] sm:text-6xl" data-es="Proyectos reales con interfaz, lógica de negocio y despliegue." data-en="Real projects with interface, business logic and deployment.">Proyectos reales con interfaz, lógica de negocio y despliegue.</h2>
					</div>

					<div class="space-y-6">
						<article class="project-card reveal grid overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.045] lg:grid-cols-[1.05fr_0.95fr]" aria-labelledby="finance-title">
							<div class="p-7 sm:p-10">
								<p class="text-sm font-semibold uppercase tracking-[0.22em] text-[color:var(--primary-on-dark)]">React · Node.js · PostgreSQL · JWT/2FA</p>
								<h3 id="finance-title" class="mt-5 text-3xl font-semibold tracking-[-0.04em] sm:text-5xl" data-es="Mis Gastos Mensuales" data-en="Monthly Expense Tracker">Mis Gastos Mensuales</h3>
								<p class="mt-6 max-w-xl text-lg leading-8 text-white/68" data-es="Aplicación para llevar el control de ingresos, gastos y balance mensual. La experiencia está pensada para revisar movimientos, entender hábitos financieros y tomar decisiones sin perderse entre hojas de cálculo." data-en="An app for tracking income, expenses and monthly balance. The experience is designed to review movements, understand spending habits and make decisions without getting lost in spreadsheets.">Aplicación para llevar el control de ingresos, gastos y balance mensual. La experiencia está pensada para revisar movimientos, entender hábitos financieros y tomar decisiones sin perderse entre hojas de cálculo.</p>
								<a href={projectLinks.finance} target="_blank" rel="noreferrer" class="magnetic mt-8 inline-flex min-h-11 items-center justify-center rounded-full border border-white/18 px-5 py-3 text-sm font-medium text-white transition hover:border-[color:var(--primary-on-dark)] hover:text-[color:var(--primary-on-dark)]" data-es="Ver en GitHub" data-en="View on GitHub">Ver en GitHub</a>
							</div>
							<div class="p-6 sm:p-10">
								<div class="project-preview" data-carousel>
									<div class="preview-panel project-media rounded-[1.5rem] border border-white/10 bg-[#07080d] p-2 shadow-[var(--shadow-product)]">
